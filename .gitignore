# .gitignore
# NEVER commit these files to GitHub

# Environment variables (contains passwords!)
.env
.env.local
.env.production

# Node.js dependencies (too large, reinstalled via npm install)
node_modules/
backend/node_modules/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/settings.json
*.code-workspace

# Logs
*.log
npm-debug.log*
